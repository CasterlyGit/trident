#!/usr/bin/env bash
# trident CLI — status | posture | counters | pause [on|off] | canary | tick
#               brain [status|fire|force|on|off|audit] | policy [show|clear] | forecast
# Thin reads of wallet.json; all math lives in the MINT daemon.
set -euo pipefail

STATE="${TRIDENT_STATE_DIR:-$HOME/.claude/state}"
WALLET="$STATE/wallet.json"
# readlink -f: survive invocation via PATH symlink (~/.local/bin/trident)
ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
MINT="$ROOT/mint/mint.py"
BRAIN="$ROOT/brain/brain.py"

age() {
  [ -f "$WALLET" ] || { echo "-"; return; }
  echo "$(( $(date +%s) - $(stat -f %m "$WALLET") ))s"
}

case "${1:-status}" in
  status)
    if [ ! -f "$WALLET" ]; then echo "trident: no wallet.json yet (mint not run?)"; exit 1; fi
    A=$(age)
    jq -r --arg age "$A" '
      "trident wallet · age \($age) · contract_ok=\(.contract_ok) · updated \(.updated_at)",
      "5h \(.telemetry.five_hour.left_pct // "?")% left · 7d \(.telemetry.seven_day.left_pct // "?")% · sessions \(.telemetry.active_sessions) · stale \(.telemetry.stale_s)s",
      "lever global=\(.lever.global) 📌 \(.lever.pinned_count) pinned\(if .lever.theater_warning then " · ⚠ THEATER" else "" end)",
      "default: \(.derived.default.envelope)",
      (.derived.per_pin | to_entries[] | "pin \(.key[0:8]): \(.value.envelope)")
    ' "$WALLET"
    # Degrade visibility: stale wallet = advisory-only.
    S=${A%s}; if [ "$S" != "-" ] && [ "$S" -gt 120 ]; then
      echo "⚠ wallet stale (${S}s > 120s) — consumers degrade to advisory-only"
    fi
    ;;
  posture)
    SID="${CLAUDE_CODE_SESSION_ID:-}"
    if [ -f "$WALLET" ] && [ $(( $(date +%s) - $(stat -f %m "$WALLET") )) -le 120 ]; then
      jq -r --arg sid "$SID" '(.derived.per_pin[$sid] // .derived.default).posture[]' "$WALLET"
    else
      echo "trident: wallet missing/stale — falling back to legacy budget-posture"
      exec "$HOME/.claude/scripts/budget-posture.sh" --legacy
    fi
    ;;
  counters)
    jq . "$STATE/trident-counters.json" 2>/dev/null || echo '{"spawns_inflight":0,"by_session":{}}'
    ;;
  pause)
    case "${2:-on}" in
      on)  touch "$STATE/trident-paused"; echo "trident paused — wallet will go stale; consumers degrade to advisory-only (fail open)";;
      off) rm -f "$STATE/trident-paused"; python3 "$MINT" --tick;;
      *)   echo "usage: trident pause [on|off]"; exit 2;;
    esac
    ;;
  canary)
    python3 -c "
import sys, os
sys.path.insert(0, os.path.join('$(dirname "$MINT")'))
import canary
ok, failures = canary.run(force=True)
print('canary: OK — contract intact' if ok else f'canary: DEGRADED — {failures}')"
    python3 "$MINT" --tick >/dev/null
    ;;
  proxy)
    case "${2:-}" in
      off) touch "$STATE/trident-proxy-off"
           launchctl unload ~/Library/LaunchAgents/com.casterly.trident-proxy.plist 2>/dev/null
           echo "proxy OFF — headless spawns go direct (env-stamp health-gate sees the flag instantly)";;
      on)  rm -f "$STATE/trident-proxy-off"
           launchctl load ~/Library/LaunchAgents/com.casterly.trident-proxy.plist 2>/dev/null
           echo "proxy ON — env-stamp re-attaches once 127.0.0.1:8742 answers";;
      *)   if nc -z 127.0.0.1 8742 2>/dev/null; then echo "proxy: LIVE on 127.0.0.1:8742"; else echo "proxy: down"; fi
           [ -f "$STATE/trident-proxy-off" ] && echo "off-flag set";;
    esac
    ;;
  tick)
    python3 "$MINT" --tick
    ;;
  brain)
    case "${2:-status}" in
      status) python3 "$BRAIN" --status;;
      fire)   python3 "$BRAIN" --fire;;
      force)  python3 "$BRAIN" --force;;
      off)    touch "$STATE/trident-brain-off"; echo "brain OFF — mechanical curves only (existing policy still honored until expiry; 'trident policy clear' to drop it)";;
      on)     rm -f "$STATE/trident-brain-off"; echo "brain ON — next eligible tick may fire";;
      audit)  tail -n "${3:-5}" "$STATE/trident-brain-audit.jsonl" 2>/dev/null | jq . || echo "no audit yet";;
      *)      echo "usage: trident brain [status|fire|force|on|off|audit [n]]"; exit 2;;
    esac
    ;;
  policy)
    case "${2:-show}" in
      show)  jq . "$STATE/trident-policy.json" 2>/dev/null || echo "no live policy (mechanical curves)";;
      clear) rm -f "$STATE/trident-policy.json"; python3 "$MINT" --tick >/dev/null; echo "policy cleared — wallet re-baked mechanical";;
      *)     echo "usage: trident policy [show|clear]"; exit 2;;
    esac
    ;;
  forecast)
    jq '.forecast // "no forecast (need ≥10min of history ring)"' "$WALLET" 2>/dev/null
    ;;
  *)
    echo "usage: trident [status|posture|counters|pause on|off|canary|tick|brain …|policy …|forecast]"; exit 2
    ;;
esac
