#!/usr/bin/env bash
# trident CLI — status | posture | counters | pause [on|off] | canary | tick
# Thin reads of wallet.json; all math lives in the MINT daemon.
set -euo pipefail

STATE="${TRIDENT_STATE_DIR:-$HOME/.claude/state}"
WALLET="$STATE/wallet.json"
MINT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/mint/mint.py"

age() {
  [ -f "$WALLET" ] || { echo "-"; return; }
  echo "$(( $(date +%s) - $(stat -f %m "$WALLET") ))s"
}

case "${1:-status}" in
  status)
    if [ ! -f "$WALLET" ]; then echo "trident: no wallet.json yet (mint not run?)"; exit 1; fi
    A=$(age)
    jq -r --arg age "$A" '
      "trident wallet · age \($age) · contract_ok=\(.contract_ok) · updated \(.updated_at)",
      "5h \(.telemetry.five_hour.left_pct // "?")% left · 7d \(.telemetry.seven_day.left_pct // "?")% · sessions \(.telemetry.active_sessions) · stale \(.telemetry.stale_s)s",
      "lever global=\(.lever.global) 📌 \(.lever.pinned_count) pinned\(if .lever.theater_warning then " · ⚠ THEATER" else "" end)",
      "default: \(.derived.default.envelope)",
      (.derived.per_pin | to_entries[] | "pin \(.key[0:8]): \(.value.envelope)")
    ' "$WALLET"
    # Degrade visibility: stale wallet = advisory-only.
    S=${A%s}; if [ "$S" != "-" ] && [ "$S" -gt 120 ]; then
      echo "⚠ wallet stale (${S}s > 120s) — consumers degrade to advisory-only"
    fi
    ;;
  posture)
    SID="${CLAUDE_CODE_SESSION_ID:-}"
    if [ -f "$WALLET" ] && [ $(( $(date +%s) - $(stat -f %m "$WALLET") )) -le 120 ]; then
      jq -r --arg sid "$SID" '(.derived.per_pin[$sid] // .derived.default).posture[]' "$WALLET"
    else
      echo "trident: wallet missing/stale — falling back to legacy budget-posture"
      exec "$HOME/.claude/scripts/budget-posture.sh" --legacy
    fi
    ;;
  counters)
    jq . "$STATE/trident-counters.json" 2>/dev/null || echo '{"spawns_inflight":0,"by_session":{}}'
    ;;
  pause)
    case "${2:-on}" in
      on)  touch "$STATE/trident-paused"; echo "trident paused — wallet will go stale; consumers degrade to advisory-only (fail open)";;
      off) rm -f "$STATE/trident-paused"; python3 "$MINT" --tick;;
      *)   echo "usage: trident pause [on|off]"; exit 2;;
    esac
    ;;
  canary)
    # Wave-1 lite: telemetry schema + wallet freshness. Full §3.9 canary lands Wave 4.
    python3 "$MINT" --tick >/dev/null
    jq -r 'if .contract_ok then "canary: OK (statusline telemetry contract intact)" else "canary: DEGRADED — contract_ok=false" end' "$WALLET"
    ;;
  tick)
    python3 "$MINT" --tick
    ;;
  *)
    echo "usage: trident [status|posture|counters|pause on|off|canary|tick]"; exit 2
    ;;
esac
